  schedule_status    String?              @default("scheduled") @db.VarChar(50)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  subtask_id         String?              @db.Uuid
  reschedule_reason  String?
  subtasks           subtasks?            @relation(fields: [subtask_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks              tasks                @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  execution_sessions execution_sessions[]

  @@index([schedule_date], map: "idx_schedule_date")
  @@index([user_id], map: "idx_schedule_user_id")
  @@schema("public")
}

model subtasks {
